# TAFLEX JS — npm Registry Configuration (GitHub Packages)
#
# npm natively resolves ${VAR} syntax from the environment at runtime.
# No secrets are stored in this file.
#
# CI (publish job):  GITHUB_TOKEN is automatically available in GitHub Actions.
#
# Local (publishing/installing):
#   export GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx  # read:packages scope PAT

@taflex:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
