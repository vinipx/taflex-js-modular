# Execution mode: web, api, or mobile
EXECUTION_MODE=web
# API provider (used when EXECUTION_MODE=api): playwright or axios
API_PROVIDER=playwright
# Path to Gherkin feature files
FEATURES_PATH=tests/bdd/features
# Path to step definition files
STEPS_PATH=tests/bdd/steps
# Browser to use: chromium, firefox, or webkit
BROWSER=chromium
# Base URL for the application under test
BASE_URL=https://playwright.dev
# Run in headless mode
HEADLESS=true
# Log level: debug, info, warn, error
LOG_LEVEL=info
